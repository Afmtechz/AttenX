<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F3F4F6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:padding="16dp"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Greeting -->
        <TextView
            android:id="@+id/txtGreeting"
            android:text="Hi Sohan 👋"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="4dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Track your attendance below"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- View Schedule button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewSchedule"
            android:text="📅  View Schedule"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="20dp"
            app:backgroundTint="#3D3A7C"
            app:cornerRadius="16dp"
            app:elevation="0dp"/>

        <!-- Overall Attendance Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#3D3A7C"
            app:strokeWidth="0dp">

            <LinearLayout
                android:padding="20dp"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:text="OVERALL ATTENDANCE"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#A5B4FC"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="8dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/txtOverallPercent"
                        android:text="0%"
                        android:textSize="48sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_weight="1"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content">

                        <TextView
                            android:id="@+id/txtPresentTotal"
                            android:text="0 Present"
                            android:textSize="14sp"
                            android:textColor="#A5B4FC"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/txtAbsentTotal"
                            android:text="0 Absent"
                            android:textSize="14sp"
                            android:textColor="#FCA5A5"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/txtTotalClasses"
                            android:text="0 Total"
                            android:textSize="12sp"
                            android:textColor="#94A3B8"
                            android:layout_marginTop="4dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Overall bunk summary -->
                <TextView
                    android:id="@+id/txtOverallBunk"
                    android:text=""
                    android:textSize="13sp"
                    android:textColor="#4ADE80"
                    android:layout_marginTop="12dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Per Subject heading -->
        <TextView
            android:text="Per Subject"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:id="@+id/layoutSubjectCards"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</ScrollView>