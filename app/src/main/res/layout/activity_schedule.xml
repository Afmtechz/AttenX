<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="#F3F4F6"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Purple Header -->
    <LinearLayout
        android:orientation="vertical"
        android:background="#3D3A7C"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Top row: back / title / date label / calendar icon -->
        <LinearLayout
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnBack"
                android:text="←"
                android:textSize="24sp"
                android:textColor="#FFFFFF"
                android:paddingEnd="16dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Schedule"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"/>

            <!-- Selected date label -->
            <TextView
                android:id="@+id/txtSelectedDate"
                android:text=""
                android:textSize="13sp"
                android:textColor="#A5B4FC"
                android:layout_marginEnd="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Month/year + calendar tap target -->
            <LinearLayout
                android:id="@+id/btnCalendar"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/day_selected_bg"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:text="📅 "
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/txtMonthYear"
                    android:text=""
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="#1F2937"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Day strip -->
        <HorizontalScrollView
            android:id="@+id/dayScrollView"
            android:scrollbars="none"
            android:layout_width="match_parent"
            android:layout_height="72dp">

            <LinearLayout
                android:id="@+id/layoutDayStrip"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"/>

        </HorizontalScrollView>

    </LinearLayout>

    <!-- Subject list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSchedule"
        android:padding="12dp"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</LinearLayout>