<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="#0F172A"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ── Top Bar ── -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="52dp"
        android:paddingBottom="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="📋"
            android:textSize="28sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <LinearLayout
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:layout_width="0dp"
            android:layout_height="wrap_content">

            <TextView
                android:text="Setup Timetable"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#F8FAFC"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Add subjects &amp; schedule your week"
                android:textSize="13sp"
                android:textColor="#94A3B8"
                android:layout_marginTop="2dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </LinearLayout>

    <!-- ── Scrollable Content ── -->
    <ScrollView
        android:layout_weight="1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="16dp">

        <LinearLayout
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- ── SECTION 1: Add Subject ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="SUBJECTS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#6366F1"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <!-- Subject input row -->
                    <LinearLayout
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <com.google.android.material.textfield.TextInputLayout
                            android:id="@+id/tilSubjectName"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:hint="Subject name"
                            android:layout_weight="1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:boxStrokeColor="#334155"
                            app:boxBackgroundColor="#0F172A"
                            app:hintTextColor="#94A3B8">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etSubjectName"
                                android:textColor="#F8FAFC"
                                android:inputType="textCapWords"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"/>

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnAddSubject"
                            android:text="Add"
                            android:textColor="#FFFFFF"
                            android:layout_marginStart="10dp"
                            android:layout_width="72dp"
                            android:layout_height="56dp"
                            app:backgroundTint="#6366F1"
                            app:cornerRadius="12dp"
                            app:elevation="0dp"/>

                    </LinearLayout>

                    <!-- Subject chips list -->
                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipGroupSubjects"
                        android:layout_marginTop="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── SECTION 2: Add to Timetable ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="TIMETABLE SLOTS"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#6366F1"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <!-- Day Spinner -->
                    <TextView
                        android:text="Day"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Spinner
                        android:id="@+id/spinnerDay"
                        android:background="@drawable/spinner_bg"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>

                    <!-- Subject Spinner -->
                    <TextView
                        android:text="Subject"
                        android:textSize="12sp"
                        android:textColor="#94A3B8"
                        android:layout_marginTop="14dp"
                        android:layout_marginBottom="6dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <Spinner
                        android:id="@+id/spinnerSubject"
                        android:background="@drawable/spinner_bg"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"/>

                    <!-- Add to Timetable button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAddToTimetable"
                        android:text="＋  Add to Timetable"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:layout_marginTop="18dp"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        app:backgroundTint="#10B981"
                        app:cornerRadius="14dp"
                        app:elevation="0dp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── SECTION 3: Current Timetable Preview ── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#1E293B"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="#334155">

                <LinearLayout
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:text="TIMETABLE PREVIEW"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="#6366F1"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <LinearLayout
                        android:id="@+id/layoutTimetablePreview"
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:id="@+id/txtNoSlots"
                        android:text="No slots added yet"
                        android:textSize="13sp"
                        android:textColor="#475569"
                        android:gravity="center"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <!-- ── BOTTOM: Done Button ── -->
    <LinearLayout
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:background="#0F172A"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDone"
            android:text="Done — Go to Dashboard →"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            app:backgroundTint="#6366F1"
            app:cornerRadius="16dp"
            app:elevation="0dp"/>

    </LinearLayout>

</LinearLayout>